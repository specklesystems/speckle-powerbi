// Groups EAV rows into structured object data.
(
    source as any,
    optional projectId as nullable text,
    optional modelId as nullable text,
    optional versionId as nullable text,
    optional rootObjectId as nullable text,
    optional token as nullable text,
    optional propertiesColumn as nullable text,
    optional shortNameLookup as nullable record,
    optional expandProperties as nullable logical,
    optional includeMaterialQuantities as nullable logical
) as table =>
    let
        FetchEavParquet = Extension.LoadFunction("FetchEavParquet.pqm"),

        Extension.LoadFunction = (fileName as text) =>
            let
                binary = Extension.Contents(fileName),
                asText = Text.FromBinary(binary)
            in
                try
                    Expression.Evaluate(asText, #shared)
                catch (e) =>
                    error
                        [
                            Reason = "Extension.LoadFunction Failure",
                            Message.Format = "Loading '#{0}' failed - '#{1}': '#{2}'",
                            Message.Parameters = {fileName, e[Reason], e[Message]},
                            Detail = [File = fileName, Error = e]
                        ],

        EavTable = if Value.Is(source, type table) then
            source
        else
            Table.Buffer(
                FetchEavParquet(
                    source,
                    projectId,
                    modelId,
                    versionId,
                    token
                )
            ),

        SelectedPropertiesColumn = if propertiesColumn = null then "Full paths" else propertiesColumn,
        ShouldExpandProperties = if expandProperties = null then false else expandProperties,
        ShouldIncludeMaterialQuantities = if includeMaterialQuantities = null then false else includeMaterialQuantities,

        PropertyPathPrefix = "properties.",
        MaterialQuantitiesPath = "properties.Material Quantities",
        MaterialQuantitiesPrefix = MaterialQuantitiesPath & ".",
        ExcludedPropertyPaths = {
            "properties.Composite Structure",
            "properties.Material Quantities",
            "properties.Parameters.Type Parameters.Structure"
        },

        RowsToRecord = (rows as table) as record =>
            Record.FromList(rows[value_text], rows[path]),

        IsExcludedPropertyPath = (path as text) as logical =>
            List.AnyTrue(
                List.Transform(
                    ExcludedPropertyPaths,
                    (excludedPath) => path = excludedPath or Text.StartsWith(path, excludedPath & ".")
                )
            ),

        IsEligiblePropertyPath = (path as any) as logical =>
            Value.Is(path, type text)
                and Text.StartsWith(path, PropertyPathPrefix)
                and not IsExcludedPropertyPath(path),

        IsMaterialQuantityPath = (path as any) as logical =>
            if not Value.Is(path, type text) or not Text.StartsWith(path, MaterialQuantitiesPrefix) then
                false
            else
                List.Count(Text.Split(Text.AfterDelimiter(path, MaterialQuantitiesPrefix), ".")) >= 2,

        MaterialRowsToRecord = (rows as table) as record =>
            let
                fieldNames = rows[fieldName],
                values = rows[value_text],
                fieldsRecord = List.Accumulate(
                    List.Positions(fieldNames),
                    [],
                    (current, index) =>
                        Record.AddField(
                            Record.RemoveFields(current, {fieldNames{index}}, MissingField.Ignore),
                            fieldNames{index},
                            values{index}
                        )
                )
            in
                Record.AddField(
                    Record.RemoveFields(fieldsRecord, {"materialName"}, MissingField.Ignore),
                    "materialName",
                    rows[materialName]{0}
                ),

        RowsToMaterialQuantities = (rows as table) as list =>
            let
                withSegments = Table.AddColumn(
                    rows,
                    "segments",
                    each Text.Split(Text.AfterDelimiter([path], MaterialQuantitiesPrefix), "."),
                    type list
                ),
                withMaterialName = Table.AddColumn(
                    withSegments,
                    "materialName",
                    each List.Last(List.FirstN([segments], List.Count([segments]) - 1)),
                    type text
                ),
                withFieldName = Table.AddColumn(
                    withMaterialName,
                    "fieldName",
                    each List.Last([segments]),
                    type text
                ),
                groupedByMaterial = Table.Group(
                    withFieldName,
                    {"materialName"},
                    {{"Material Quantity", MaterialRowsToRecord, type record}}
                )
            in
                groupedByMaterial[Material Quantity],

        RowsToGroupedObjectWithoutProperties = (rows as table) as record =>
            let
                rowsRecord = RowsToRecord(rows)
            in
                [
                    #"Speckle Type" = Record.FieldOrDefault(rowsRecord, "speckle_type", null),
                    #"Application ID" = Record.FieldOrDefault(rowsRecord, "applicationId", null),
                    Rows = rowsRecord
                ],

        RowsToGroupedObjectWithProperties = (rows as table) as record =>
            let
                rowsRecord = RowsToRecord(rows),
                propertyRows = Table.SelectRows(rows, each IsEligiblePropertyPath([path])),
                propertyPaths = propertyRows[path],
                propertyNames = if SelectedPropertiesColumn = "Full paths" then
                    propertyPaths
                else
                    List.Transform(propertyPaths, each Record.Field(shortNameLookup, _)),
                propertiesRecord = Record.FromList(propertyRows[value_text], propertyNames)
            in
                [
                    #"Speckle Type" = Record.FieldOrDefault(rowsRecord, "speckle_type", null),
                    #"Application ID" = Record.FieldOrDefault(rowsRecord, "applicationId", null),
                    properties = propertiesRecord,
                    Rows = rowsRecord
                ],

        IncludePropertiesColumn = SelectedPropertiesColumn <> "None (fastest)" and not ShouldExpandProperties,
        ShouldPivotProperties = SelectedPropertiesColumn <> "None (fastest)" and ShouldExpandProperties,
        RowsToGroupedObject = if IncludePropertiesColumn then
            RowsToGroupedObjectWithProperties
        else
            RowsToGroupedObjectWithoutProperties,

        GroupedByObjectId = Table.Group(
            EavTable,
            {"object_id"},
            {{"Grouped Object", RowsToGroupedObject, type record}},
            GroupKind.Local
        ),

        GroupedObjectFields = if IncludePropertiesColumn then
            {"Speckle Type", "Application ID", "properties", "Rows"}
        else
            {"Speckle Type", "Application ID", "Rows"},

        ExpandedGroupedByObjectId = Table.ExpandRecordColumn(
            GroupedByObjectId,
            "Grouped Object",
            GroupedObjectFields,
            GroupedObjectFields
        ),

        DataObjects = Table.SelectRows(
            ExpandedGroupedByObjectId,
            each [#"Speckle Type"] <> null
                and Text.Contains(Text.From([#"Speckle Type"]), "DataObject")
        ),

        FinalGroupedByObjectId = if Table.IsEmpty(DataObjects) then
            ExpandedGroupedByObjectId
        else
            DataObjects,

        EligiblePropertyRows = if ShouldPivotProperties then
            Table.SelectRows(EavTable, each IsEligiblePropertyPath([path]))
        else
            #table({"object_id", "path", "value_text"}, {}),

        NamedPropertyRows = if ShouldPivotProperties and SelectedPropertiesColumn = "Short names (slowest)" then
            Table.TransformColumns(
                EligiblePropertyRows,
                {{"path", each Record.Field(shortNameLookup, _), type text}}
            )
        else
            EligiblePropertyRows,

        PivotPropertyNames = if ShouldPivotProperties then
            List.Buffer(List.Distinct(NamedPropertyRows[path]))
        else
            {},

        PivotedProperties = if ShouldPivotProperties and not List.IsEmpty(PivotPropertyNames) then
            Table.Pivot(
                Table.SelectColumns(NamedPropertyRows, {"object_id", "path", "value_text"}),
                PivotPropertyNames,
                "path",
                "value_text"
            )
        else
            null,

        ExpandedWithPivotedProperties = if ShouldPivotProperties and not List.IsEmpty(PivotPropertyNames) then
            let
                nested = Table.NestedJoin(
                    FinalGroupedByObjectId,
                    {"object_id"},
                    PivotedProperties,
                    {"object_id"},
                    "Pivoted Properties",
                    JoinKind.LeftOuter
                )
            in
                Table.ExpandTableColumn(
                    nested,
                    "Pivoted Properties",
                    PivotPropertyNames,
                    PivotPropertyNames
                )
        else
            FinalGroupedByObjectId,

        MaterialQuantityRows = if ShouldIncludeMaterialQuantities then
            Table.SelectRows(EavTable, each IsMaterialQuantityPath([path]))
        else
            #table({"object_id", "path", "value_text"}, {}),

        GroupedMaterialQuantities = if ShouldIncludeMaterialQuantities and not Table.IsEmpty(MaterialQuantityRows) then
            Table.Group(
                MaterialQuantityRows,
                {"object_id"},
                {{"materialQuantities", RowsToMaterialQuantities, type list}}
            )
        else
            null,

        JoinedMaterialQuantities = if ShouldIncludeMaterialQuantities and GroupedMaterialQuantities <> null then
            let
                nested = Table.NestedJoin(
                    ExpandedWithPivotedProperties,
                    {"object_id"},
                    GroupedMaterialQuantities,
                    {"object_id"},
                    "Material Quantities",
                    JoinKind.LeftOuter
                ),
                expanded = Table.ExpandTableColumn(
                    nested,
                    "Material Quantities",
                    {"materialQuantities"},
                    {"Material Quantities"}
                )
            in
                Table.ReplaceValue(
                    expanded,
                    null,
                    {},
                    Replacer.ReplaceValue,
                    {"Material Quantities"}
                )
        else if ShouldIncludeMaterialQuantities then
            Table.AddColumn(ExpandedWithPivotedProperties, "Material Quantities", each {}, type list)
        else
            ExpandedWithPivotedProperties,

        RenamedFinalTable = Table.RenameColumns(
            JoinedMaterialQuantities,
            {
                {"object_id", "Object IDs"},
                {"Rows", "data"}
            }
        )
    in
        RenamedFinalTable
